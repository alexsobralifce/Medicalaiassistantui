generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Patient {
  id            String         @id @default(uuid())
  name          String
  age           Int
  gender        String
  lastVisit     DateTime?
  image         String?
  phone         String?
  city          String?
  state         String?
  dob           String?
  cpf           String?        @unique
  doctorId      String?
  doctor        User?          @relation(fields: [doctorId], references: [id])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  consultations Consultation[]

  @@map("patients")
}

model Consultation {
  id                String             @id @default(uuid())
  patientId         String
  patient           Patient            @relation(fields: [patientId], references: [id], onDelete: Cascade)
  transcript        String[]
  transcriptClean   String? // Prompt 1: texto limpo e organizado
  anamnesisJson     Json? // Prompt 2: JSON estruturado da anamnese
  anamnesisMarkdown String? // Prompt 3: Markdown formatado para exibição
  notes             String?
  diagnosis         String?
  status            ConsultationStatus @default(DRAFT)
  signedAt          DateTime? // Timestamp da assinatura digital
  signedByDoctorId  String? // ID do médico que assinou
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@map("consultations")
}

enum ConsultationStatus {
  DRAFT
  REVIEW
  COMPLETED
}

model Cid {
  code        String @id
  description String

  @@map("cids")
}

enum Role {
  ADMIN
  DOCTOR
}

model User {
  id        String    @id @default(uuid())
  name      String
  email     String    @unique
  password  String
  crm       String?
  role      Role      @default(DOCTOR)
  patients  Patient[]
  createdAt DateTime  @default(now())

  @@map("users")
}
